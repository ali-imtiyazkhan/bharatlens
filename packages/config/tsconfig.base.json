{
  "compilerOptions": {
    "ignoreDeprecations": "5.0",
    "target": "es2022",
    "module": "Node16",
    "lib": ["es2022", "dom", "dom.iterable"],
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true
  }
}
